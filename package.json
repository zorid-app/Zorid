{
  "name": "zorid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:biome": "biome ci .",
    "lint:biome": "pnpm check:biome",
    "lint:boundaries": "node scripts/check-import-boundaries.mjs",
    "lint": "pnpm lint:biome && pnpm lint:boundaries",
    "knip": "knip",
    "typecheck": "pnpm run prepare:ui-vue && tsc -b tsconfig.packages.json --pretty false",
    "build": "pnpm run prepare:ui-vue && tsc -b tsconfig.packages.json --pretty false",
    "test": "pnpm run prepare:ui-vue && vitest run",
    "quality:fast": "pnpm lint && pnpm typecheck && pnpm test",
    "quality:desktop": "pnpm desktop:build",
    "quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm perf:smoke && pnpm knip && pnpm quality:desktop",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "desktop:dev": "pnpm --filter @zorid/desktop-app run dev",
    "desktop:dev:watch": "pnpm --filter @zorid/desktop-app run dev:watch",
    "desktop:start": "pnpm --filter @zorid/desktop-app run start",
    "desktop:build": "pnpm --filter @zorid/desktop-app run build",
    "desktop:pack": "pnpm --filter @zorid/desktop-app run pack",
    "desktop:dist": "pnpm --filter @zorid/desktop-app run dist",
    "prepare:ui-vue": "pnpm --filter @zorid/ui-vue run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@types/node": "latest",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "electron": "^42.3.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.14.2",
    "typescript": "latest",
    "vitest": "latest",
    "vue": "^3.5.34"
  }
}
