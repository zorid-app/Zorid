{
  "name": "@zorid/ui-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./components.css": "./dist/components.css"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit --pretty false",
    "build": "vue-tsc --noEmit --pretty false && tsc -b --pretty false && node scripts/copy-assets.mjs"
  },
  "dependencies": {
    "reka-ui": "^2.9.8",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.2"
  }
}
