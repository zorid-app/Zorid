{
  "name": "@zorid/desktop-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "node ../../scripts/desktop-dev.mjs",
    "dev:watch": "node ../../scripts/desktop-dev.mjs --watch",
    "typecheck": "tsc -b --pretty false && vue-tsc --noEmit --pretty false",
    "build": "pnpm typecheck && electron-vite build",
    "start": "pnpm build && electron-vite preview --skipBuild",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@zorid/file-explorer": "workspace:*",
    "@zorid/plugin-data-views": "workspace:*",
    "@zorid/plugin-images": "workspace:*",
    "@zorid/ui-vue": "workspace:*",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.2"
  },
  "description": "Zorid desktop app",
  "homepage": "https://zorid.app",
  "author": {
    "name": "Zorid",
    "email": "hello@zorid.app"
  }
}
